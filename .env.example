# Required: a strong random string used to authenticate all requests
# Generate with: openssl rand -hex 32
API_KEY=your-secret-api-key-here

# Optional: path to the SQLite database file
# On Railway, set this to /data/health.db so it lands on the persistent volume
DB_PATH=/data/health.db

# Railway sets this automatically; you can override for local dev
PORT=3000
